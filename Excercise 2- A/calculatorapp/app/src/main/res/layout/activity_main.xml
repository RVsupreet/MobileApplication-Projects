<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D9D2E9">

    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Title -->
            <TextView
                android:text="Basic Calculator"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

            <!-- Value 1 -->
            <EditText
                android:id="@+id/etValue1"
                android:hint="Enter Value 1"
                android:inputType="numberDecimal"
                android:backgroundTint="#000000"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"/>

            <!-- Value 2 -->
            <EditText
                android:id="@+id/etValue2"
                android:hint="Enter Value 2"
                android:inputType="numberDecimal"
                android:backgroundTint="#000000"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"/>

            <!-- Result -->
            <TextView
                android:id="@+id/tvResult"
                android:text="Result"
                android:textSize="16sp"
                android:padding="12dp"
                android:background="#B9AEDC"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"/>

            <!-- Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnAdd"
                    android:text="+"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_margin="6dp"
                    android:backgroundTint="#5E3AA5"
                    android:textColor="#FFFFFF"/>

                <Button
                    android:id="@+id/btnSub"
                    android:text="-"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_margin="6dp"
                    android:backgroundTint="#5E3AA5"
                    android:textColor="#FFFFFF"/>

                <Button
                    android:id="@+id/btnMul"
                    android:text="*"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_margin="6dp"
                    android:backgroundTint="#5E3AA5"
                    android:textColor="#FFFFFF"/>

                <Button
                    android:id="@+id/btnDiv"
                    android:text="/"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_margin="6dp"
                    android:backgroundTint="#5E3AA5"
                    android:textColor="#FFFFFF"/>

                <Button
                    android:id="@+id/btnMod"
                    android:text="%"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_margin="6dp"
                    android:backgroundTint="#5E3AA5"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>